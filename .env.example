# ── Google Maps (delivery distance calculator) ───────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# Server-side key for Distance Matrix API (can be the same key)
GOOGLE_MAPS_API_KEY=

# ── App ──────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://bouncefxsiteandportal.vercel.app
# Email allowed to access the /admin dashboard (required for a real launch)
ADMIN_EMAIL=Info@bouncefxpartyrentals.com

# ── Prototype mode ───────────────────────────────────────
# Set ADMIN_DEMO=1 to open /admin with NO login on a hosted prototype (e.g.
# Vercel) so a client can click around. This ONLY applies when Supabase is NOT
# configured — so the admin only ever shows sample bookings and edits are
# ephemeral (uploads preview, saves succeed, nothing persists past the session).
# Once Supabase is connected, ADMIN_DEMO is ignored and owner login is required
# (so real customer data is never exposed without auth).
# ADMIN_DEMO=1
