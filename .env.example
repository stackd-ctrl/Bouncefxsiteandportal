# ── Supabase ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe ───────────────────────────────────────────────
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Resend (transactional email) ─────────────────────────
RESEND_API_KEY=
# The "from" address must be on a Resend-verified domain
RESEND_FROM_EMAIL=Bounce FX <bookings@bouncefxpartyrentals.com>

# ── Google Maps (delivery distance calculator) ───────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# Server-side key for Distance Matrix API (can be the same key)
GOOGLE_MAPS_API_KEY=

# ── App ──────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Email allowed to access the /admin dashboard (required for a real launch)
ADMIN_EMAIL=Info@bouncefxpartyrentals.com

# ── Prototype mode ───────────────────────────────────────
# Set ADMIN_DEMO=1 to open /admin with NO login on any host (e.g. a Vercel
# prototype) so a client can click around. Without Supabase, edits are
# ephemeral (uploads preview, saves succeed, but nothing persists past the
# session). With Supabase connected, edits DO persist. NEVER enable this for a
# live site holding real customer bookings.
# ADMIN_DEMO=1
